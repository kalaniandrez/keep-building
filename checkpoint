#!/usr/bin/env bash
# checkpoint "message" -- save your work: stage all, commit, push.
# The keystone habit. Run it every time something works. Works in any git repo.
set -euo pipefail

MSG="${*:-}"
[ -z "$MSG" ] && { echo 'usage: checkpoint "what you just got working"' >&2; exit 1; }

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "Not in a git repo." >&2; exit 1; }
cd "$ROOT"

[ -z "$(git status --porcelain)" ] && { echo "Clean tree, nothing to checkpoint."; exit 0; }

# Optional project pre-checkpoint hook (lint, tests, audit). Non-fatal.
[ -x .failover/pre-checkpoint.sh ] && { .failover/pre-checkpoint.sh || echo "(pre-checkpoint hook flagged issues; committing anyway)"; }

TS="$(date '+%Y-%m-%d %H:%M')"
N="$(git status --porcelain | wc -l | tr -d ' ')"
git add -A
git commit -q -m "checkpoint: $MSG ($TS)"
echo "  committed $(git rev-parse --short HEAD)  ($N files)"

# Push if there's a remote we can reach. Never block on offline.
if git remote | grep -q .; then
  BR="$(git branch --show-current)"
  git push -q origin "$BR" 2>/dev/null && echo "  pushed to origin/$BR" || echo "  (push skipped: offline / no upstream -- commit is saved locally)"
fi
